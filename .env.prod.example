# =============================================================================
# LegacyX — Production Environment Template
# -----------------------------------------------------------------------------
# Copy to `.env.prod` and fill in real values. NEVER commit `.env.prod`.
# Generate every "(rand)" secret with: openssl rand -base64 32
#
# Two production paths are supported — comments mark which vars to set:
#   [DO]  DigitalOcean Droplet + Managed MySQL + Spaces   (docker-compose.do.yml)
#   [ALL] All-in-one — MySQL + MinIO containers on host   (docker-compose.prod.yml)
#
# ⚠️  DOCKER --env-file QUIRK: do NOT wrap values in double quotes here.
#     `docker run --env-file` does not interpret quotes — they become literal
#     characters in the value. Use bare values:
#         DATABASE_URL=mysql://user:pass@host:25060/db?sslaccept=strict
#     NOT:
#         DATABASE_URL="mysql://user:pass@host:25060/db?sslaccept=strict"
#
# See docs/DEPLOYMENT.md for the full walkthrough.
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# ----- Image tag (for rollback via `IMAGE_TAG=v1.2.3 docker compose up -d`) ---
IMAGE_TAG=latest

# ----- Public ports (host → container). Restricted to 127.0.0.1 in do.yml. ---
API_PORT=3001
AI_PORT=3002
BACKOFFICE_PORT=3003
PATIENT_PORT=3004
WORKER_METRICS_PORT=9464

# =============================================================================
# Database (MySQL 8)
# =============================================================================
# [DO]  Managed MySQL endpoint from the DO console + sslaccept=strict + CA cert.
#       Example (NO double quotes — docker --env-file treats them as literal chars):
DATABASE_URL=mysql://doadmin:STRONG_PASS@db-mysql-sgp1-XXXXX.b.db.ondigitalocean.com:25060/legacyx?sslaccept=strict&sslcert=/run/secrets/db-ca.crt
#
# [ALL] Only when you use docker-compose.prod.yml (internal mysql container):
# MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# MYSQL_DATABASE=legacyx
# DATABASE_URL=mysql://root:CHANGE_ME_STRONG_PASSWORD@mysql:3306/legacyx

# =============================================================================
# Redis (BullMQ + cache) — runs in-cluster on both paths
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# Object Storage
# =============================================================================
# [DO]  DigitalOcean Spaces (S3-compatible, virtual-host style → path-style=false)
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_ACCESS_KEY=CHANGE_ME_spaces_key
S3_SECRET_KEY=CHANGE_ME_spaces_secret
S3_BUCKET=legacyx-prod
S3_FORCE_PATH_STYLE=false
#
# [ALL] Only when you use docker-compose.prod.yml (internal minio container):
# MINIO_ROOT_USER=legacyx
# MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=legacyx
# S3_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
# S3_BUCKET=legacyx-prod
# S3_FORCE_PATH_STYLE=true

# =============================================================================
# Auth — REQUIRED, generate fresh values
# =============================================================================
# (rand) generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Backoffice OTP. MUST be empty in prod (defaults to "" in code → rejects all).
# Setting a value re-enables the universal-OTP shortcut — DEV ONLY.
DEV_OTP=

# Header-only context mode (workers, smoke tests, /api/dev/identities). The
# api-server REFUSES to honour x-tenant-id / x-user-id in production unless
# the request carries x-internal-secret matching this value.
# (rand) REQUIRED in prod — generate with: openssl rand -base64 32
INTERNAL_API_SECRET=CHANGE_ME_openssl_rand_base64_32

# Set to "1" to expose /api/dev/identities in production (combined with
# INTERNAL_API_SECRET above). Off in dev = always available.
ALLOW_DEV_IDENTITIES=

# =============================================================================
# Encryption KMS Master Key — CRITICAL
# =============================================================================
# Used by AES-256-GCM column encryption AND searchableHash() for phoneHash.
# ⚠️  IF YOU CHANGE THIS AFTER FIRST DEPLOY: every encrypted column becomes
#     unreadable and every patient becomes un-login-able. Back this up in a
#     password manager BEFORE running the first migration.
# ⚠️  NEVER put a `# comment` after the value on the SAME line — docker run
#     --env-file preserves it literally, docker compose --env-file strips it,
#     causing seed-vs-runtime hash mismatch (lookups silently return empty).
# (rand) generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_byte_kms_master_key__

# =============================================================================
# Public URLs (used by browsers + cross-app server actions)
# =============================================================================
# Public HTTPS base of the api-server (browsers + LINE/payment webhooks see this).
API_BASE_URL=https://api-legacyx.unityx.group
NEXT_PUBLIC_API_URL=https://api-legacyx.unityx.group

# Internal docker-network URL (server-side server actions only).
API_INTERNAL_URL=http://api-server:3001

# Public HTTPS base of the patient-app (used to build LINE Login callback URL).
# Must match the URL registered under "Callback URL" on the LINE Login channel:
#   ${PATIENT_APP_BASE_URL}/api/v1/patient/me/line/link/callback
PATIENT_APP_BASE_URL=https://m-legacyx.unityx.group

# Allowed origins for backoffice / patient-app server actions (comma-separated).
SERVER_ACTIONS_ALLOWED_ORIGINS=https://app-legacyx.unityx.group,https://m-legacyx.unityx.group

# Single-tenant routing (future multi-tenant resolves from hostname).
PATIENT_APP_TENANT_SLUG=legacyx
NEXT_PUBLIC_TENANT_SLUG=legacyx

# =============================================================================
# LINE — Messaging API (push) + Login (patient self-link OAuth)
# =============================================================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=
NEXT_PUBLIC_LIFF_ID=

LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# Deep-link shown to patients after binding LINE so they add the OA as a friend
# (required for push messages to land).
NEXT_PUBLIC_LINE_OA_ADD_FRIEND_URL=

# =============================================================================
# Notification provider routing (read by worker-engine)
# =============================================================================
# Each channel picks its provider independently. Default = "console" (writes to
# storage/notifications/{channel}.log — dev-only). Set the real provider once
# the API keys below are configured.
#   NOTIFICATION_LINE_PROVIDER  = "console" | "line-messaging-api"
#   NOTIFICATION_SMS_PROVIDER   = "console" | "twilio"
#   NOTIFICATION_EMAIL_PROVIDER = "console" | "sendgrid"
NOTIFICATION_LINE_PROVIDER=line-messaging-api
NOTIFICATION_SMS_PROVIDER=console
NOTIFICATION_EMAIL_PROVIDER=console

# ----- SMS (Twilio) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@unityx.group

# =============================================================================
# Worker tick configuration (optional — these are the defaults)
# =============================================================================
# NOTIFICATION_TICK_MS=5000
# CRM_CRON_TICK_MS=3600000
# APPOINTMENT_REMINDER_TICK_MS=60000
# APPOINTMENT_REMINDER_OFFSETS_MIN=15

# =============================================================================
# AI Service (Phase Q — Google Gemini)
# =============================================================================
# Leave blank to fall back to the deterministic heuristic provider (good for
# private staging / CI). Set both keys to enable real LLM calls.
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-1.5-flash
GEMINI_MODEL_VISION=gemini-1.5-flash
AI_SERVICE_URL=http://ai-service:3002
# not exposed publicly today; placeholder
NEXT_PUBLIC_AI_SERVICE_URL=https://api-legacyx.unityx.group

# =============================================================================
# Payment Gateway (placeholder)
# =============================================================================
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# =============================================================================
# Observability
# =============================================================================
# Required to expose /api/metrics in production (Bearer token). Empty → 503.
# (rand) generate with: openssl rand -base64 32
METRICS_BEARER_TOKEN=CHANGE_ME_for_prometheus_scrape
OTEL_EXPORTER_OTLP_ENDPOINT=
