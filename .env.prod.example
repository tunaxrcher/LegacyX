# =====================================================
# LegacyX — Production Environment Template
# Copy to .env.prod and fill in secrets. NEVER commit .env.prod.
# Generate strong secrets with: openssl rand -base64 32
# =====================================================

NODE_ENV=production
LOG_LEVEL=info

# ----- Image tag -----
IMAGE_TAG=latest

# ----- Public ports (host → container) -----
API_PORT=3001
AI_PORT=3002
BACKOFFICE_PORT=3003
PATIENT_PORT=3004
WORKER_METRICS_PORT=9464

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=legacyx
DATABASE_URL=mysql://root:CHANGE_ME_STRONG_PASSWORD@mysql:3306/legacyx

# ----- Redis -----
REDIS_URL=redis://redis:6379

# ----- Object Storage -----
MINIO_ROOT_USER=legacyx
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=legacyx
S3_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
S3_BUCKET=legacyx-prod
S3_FORCE_PATH_STYLE=true

# ----- Auth (REQUIRED — generate fresh values) -----
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ----- Encryption KMS Master Key (REQUIRED — 32 bytes / 256 bits) -----
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_byte_kms_master_key__

# ----- AI Service (Google Gemini — Phase Q) -----
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-1.5-flash
GEMINI_MODEL_VISION=gemini-1.5-flash
AI_SERVICE_URL=http://ai-service:3002

# ----- LINE Messaging API -----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=

# ----- SMS (Twilio) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@example.com

# ----- Payment Gateway -----
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_BEARER_TOKEN=CHANGE_ME_for_prometheus_scrape

# ----- Notification provider selection (console|line|sms|email) -----
NOTIFICATION_PROVIDERS=line,email

# ----- Internal API URL for backoffice/patient apps to reach api-server -----
API_INTERNAL_URL=http://api-server:3001
NEXT_PUBLIC_API_URL=http://api-server:3001
