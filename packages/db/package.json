{
  "name": "@legacyx/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "format": "prisma format",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
