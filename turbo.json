{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.*"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "JWT_SECRET",
    "JWT_ACCESS_TTL",
    "JWT_REFRESH_TTL",
    "ENCRYPTION_MASTER_KEY",
    "DEV_OTP",
    "ALLOW_DEV_IDENTITIES",
    "INTERNAL_API_SECRET",
    "METRICS_BEARER_TOKEN",
    "API_BASE_URL",
    "PATIENT_APP_TENANT_SLUG",
    "NEXT_PUBLIC_TENANT_SLUG",
    "NEXT_PUBLIC_LIFF_ID",
    "AI_SERVICE_URL",
    "AI_SERVICE_PORT",
    "NEXT_PUBLIC_AI_SERVICE_URL",
    "GEMINI_API_KEY",
    "GOOGLE_API_KEY",
    "GEMINI_MODEL_TEXT",
    "GEMINI_MODEL_VISION",
    "CRM_CRON_TICK_MS",
    "NOTIFICATION_TICK_MS",
    "LINE_CHANNEL_ACCESS_TOKEN",
    "LINE_CHANNEL_SECRET",
    "PAYMENT_GATEWAY_API_KEY",
    "PAYMENT_GATEWAY_WEBHOOK_SECRET",
    "LOG_LEVEL",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "SERVER_ACTIONS_ALLOWED_ORIGINS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false
    },
    "migrate:deploy": {
      "cache": false
    },
    "seed": {
      "cache": false
    }
  }
}
