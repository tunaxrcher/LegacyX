# =====================================================
# LegacyX — Local Development Environment
# Copy to .env and adjust as needed
# =====================================================

NODE_ENV=development

# ----- Database (MySQL 8) -----
DATABASE_URL="mysql://root:mypassword@localhost:9251/demo"

# ----- Redis (BullMQ + cache) -----
REDIS_URL="redis://localhost:9152"

# ----- Object Storage (MinIO local / S3 / DO Spaces prod) -----
# Local MinIO defaults — for DO Spaces use:
#   S3_ENDPOINT="https://sgp1.digitaloceanspaces.com"
#   S3_REGION="sgp1"
#   S3_FORCE_PATH_STYLE=false   (DO Spaces wants virtual-host style)
S3_ENDPOINT="http://localhost:9153"
S3_REGION="us-east-1"
S3_ACCESS_KEY="legacyx"
S3_SECRET_KEY="legacyx-secret"
S3_BUCKET="legacyx-dev"
S3_FORCE_PATH_STYLE=true

# ----- Auth (Patient JWT) -----
# Backoffice uses opaque DB sessions; only the patient app uses JWT.
JWT_SECRET="change-me-in-production-please-use-openssl-rand-base64-32"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ----- Auth (Backoffice Phone + OTP) -----
# Dev shortcut: when DEV_OTP is unset, the universal OTP "123456" is accepted.
# In production this defaults to empty string (rejects everything) — you MUST
# either swap loginByPhone for a real SMS provider OR explicitly set DEV_OTP.
DEV_OTP="123456"

# ----- Internal API auth (header-only context mode) -----
# Required in production to allow header-based actor injection (workers, smoke
# tests, /api/dev/identities). Leave blank in dev — header mode is open in dev.
INTERNAL_API_SECRET=""
# Set ALLOW_DEV_IDENTITIES=1 to expose /api/dev/identities in production
# (combined with INTERNAL_API_SECRET above). Off in dev = always available.
ALLOW_DEV_IDENTITIES=""

# ----- Encryption (KMS Master Key for DEK envelope) -----
# CRITICAL — also used by `searchableHash()` for phoneHash. If this is unset
# the api-server, worker-engine, AND seed all refuse to start (no default).
ENCRYPTION_MASTER_KEY="dev-only-do-not-use-in-prod-32bytes!!"

# ----- Patient App tenant routing -----
# Single-tenant default. Future multi-tenant builds resolve from hostname.
PATIENT_APP_TENANT_SLUG="legacyx"
NEXT_PUBLIC_TENANT_SLUG="legacyx"
NEXT_PUBLIC_LIFF_ID=""

# ----- Cross-app API base URL -----
# Backoffice + patient-app server actions call the api-server via this URL.
API_BASE_URL="http://localhost:3001"
# CSRF allowlist for Server Actions (comma-separated)
SERVER_ACTIONS_ALLOWED_ORIGINS="http://localhost:3003,http://localhost:3004"

# ----- AI Service (external providers) -----
# Phase Q — All clinical AI (intake / SOAP / vision) runs on Google Gemini.
# Leave blank to use the deterministic heuristic fallback (good for CI/dev).
GEMINI_API_KEY=""
# GOOGLE_API_KEY="" # alias also accepted
GEMINI_MODEL_TEXT="gemini-1.5-flash"
GEMINI_MODEL_VISION="gemini-1.5-flash"
AI_SERVICE_PORT=3002
AI_SERVICE_URL="http://localhost:3002"
NEXT_PUBLIC_AI_SERVICE_URL="http://localhost:3002"

# ----- LINE Messaging API (push notifications from worker-engine) -----
# Channel: "Messaging API". Used to send LINE Bot push messages.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# ----- LINE Login (patient self-link OAuth 2.0) -----
# Channel: "LINE Login" (separate from Messaging API channel but lives in the
# same Provider). Powers the "ผูก LINE" button in the patient app. Leave empty
# to disable the binding flow — the dispatcher will still try to push to any
# patient who was bound elsewhere (e.g. via LIFF or seed).
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
# Public URL the api-server is reachable at (used to build the OAuth callback
# absolute URL sent to LINE). MUST be one of the registered Callback URLs on
# the LINE Login channel: <PATIENT_APP_BASE_URL>/api/v1/patient/me/line/link/callback
PATIENT_APP_BASE_URL="http://localhost:3004"
# Add-friend deep-link to the LINE OA shown after successful linking (so
# patients add the bot as a friend; required for push to land).
NEXT_PUBLIC_LINE_OA_ADD_FRIEND_URL=""

# ----- Payment Gateway (placeholder) -----
PAYMENT_GATEWAY_API_KEY=""
PAYMENT_GATEWAY_WEBHOOK_SECRET=""

# ----- Worker tick configuration -----
# Notification dispatcher (drain NotificationLog PENDING) — default 5s
NOTIFICATION_TICK_MS=5000
# CRM cron (review request, rebooking, wallet expiring, birthday) — default 1h
CRM_CRON_TICK_MS=3600000
# Appointment reminder cron — default 60s. Lower = more precise reminders.
APPOINTMENT_REMINDER_TICK_MS=60000
# Comma-separated minutes-before list. Examples:
#   "15"            → only 15-minute reminder
#   "1440,60,15"    → 1 day + 1 hour + 15 minutes
APPOINTMENT_REMINDER_OFFSETS_MIN="15"

# ----- Notification provider routing -----
# Pick the real provider per channel (default = "console" → logs to
# apps/worker-engine/storage/notifications/{channel}.log). Set to the
# corresponding real provider once you've configured the API keys above.
#   NOTIFICATION_LINE_PROVIDER  = "console" | "line-messaging-api"
#   NOTIFICATION_SMS_PROVIDER   = "console" | "twilio"
#   NOTIFICATION_EMAIL_PROVIDER = "console" | "sendgrid"
NOTIFICATION_LINE_PROVIDER="line-messaging-api"
NOTIFICATION_SMS_PROVIDER="console"
NOTIFICATION_EMAIL_PROVIDER="console"

# ----- Observability -----
LOG_LEVEL="debug"
# Required to expose /api/metrics in production (Bearer token).
# In dev, /api/metrics is open unless you set this.
METRICS_BEARER_TOKEN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
